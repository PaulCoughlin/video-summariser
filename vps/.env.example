# Copy to .env and fill in. Never commit the real .env.

# Required: get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: shown in OpenRouter analytics so you can see traffic by app.
OPENROUTER_REFERER=https://github.com/PaulCoughlin/video-summariser
OPENROUTER_APP_TITLE=Video Summariser

# Optional: per-IP daily limit (default 10).
RATE_LIMIT_PER_DAY=10

# --- Proxy (pick ONE option; YouTube blocks datacenter IPs on any VPS) ---

# Option A: full proxy URL. Most flexible — works with any provider and lets
# you use a literal IP, avoiding DNS issues inside the container. Get it from
# your provider's dashboard. Examples:
#   PROXY_URL=http://USERNAME:PASSWORD@1.2.3.4:8080
#   PROXY_URL=http://USERNAME:PASSWORD@premium.example.com:7777
PROXY_URL=

# Option B: Webshare backbone gateway (paid Residential plan only). Free
# Webshare gives you specific IPs — those go in PROXY_URL above instead.
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
