# Copy to .env and fill in. Never commit the real .env.

# Required: get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: shown in OpenRouter analytics so you can see traffic by app.
OPENROUTER_REFERER=https://github.com/PaulCoughlin/video-summariser
OPENROUTER_APP_TITLE=Video Summariser

# Optional: per-IP daily limit (default 10).
RATE_LIMIT_PER_DAY=10

# --- Proxy (pick ONE option; YouTube blocks datacenter IPs on any VPS) ---

# Option A: multiple proxy IPs with shared credentials, tried in order.
# The app falls over to the next IP on connection or block errors. Use this
# with Webshare's free plan — the dashboard gives you 10 IPs, paste a few.
# Each PROXY_HOST_N is "IP" (port defaults to 80) or "IP:port".
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_HOST_1=
PROXY_HOST_2=
PROXY_HOST_3=
PROXY_HOST_4=
PROXY_HOST_5=

# Option B: a single fully-formed proxy URL. Used as fallback when Option A
# isn't set. Most flexible if you only have one proxy.
#   PROXY_URL=http://USERNAME:PASSWORD@1.2.3.4:8080
PROXY_URL=

# Option C: Webshare backbone gateway via p.webshare.io (requires that
# hostname to resolve from inside the container — many Docker setups can't).
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
